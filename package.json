{
  "name": "beacon-opencode",
  "version": "2.1.0",
  "type": "module",
  "description": "Beacon — semantic code search for OpenCode (replaces grep with hybrid search)",
  "author": {
    "name": "keybangz"
  },
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/beacon.d.ts",
      "default": "./dist/beacon.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/keybangz/beacon-opencode"
  },
  "files": [
    "dist/",
    "command/",
    "config/",
    "scripts/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "keywords": [
    "opencode",
    "opencode-plugin",
    "semantic-search",
    "code-search",
    "embeddings",
    "vector-search",
    "bm25",
    "hybrid-search",
    "grep-replacement"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "bun build ./beacon.ts --outdir dist --target bun --sourcemap=inline",
    "dev": "bun build ./beacon.ts --outdir dist --target bun --sourcemap=inline --watch",
    "test": "bun test",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "bun run clean && bun run build",
    "postinstall": "node scripts/setup.cjs"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "fast-glob": "^3.3.0",
    "hnswlib-node": "^3.0.0",
    "onnxruntime-node": "^1.24.3",
    "picomatch": "^4.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/picomatch": "^4.0.2",
    "bun-types": "latest",
    "glob": "^11.0.0"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@opencode-ai/plugin": {
      "optional": false
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.23"
  }
}

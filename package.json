{
  "name": "beacon-opencode",
  "version": "2.1.0",
  "type": "module",
  "description": "Beacon — semantic code search for OpenCode (replaces grep with hybrid search)",
  "author": {
    "name": "Sagar MK"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sagarmk/beacon-opencode"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "semantic-search",
    "code-search",
    "embeddings",
    "vector-search",
    "bm25",
    "hybrid-search",
    "grep-replacement"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "hnswlib-node": "^3.0.0",
    "onnxruntime-node": "^1.24.3",
    "picomatch": "^4.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/picomatch": "^4.0.2",
    "better-sqlite3": "^11.0.0",
    "typescript": "^5.3.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@opencode-ai/plugin": {
      "optional": false
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    ".opencode/",
    "config/",
    "scripts/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "bin": {
    "beacon-opencode": "./scripts/download-model.ts"
  },
  "main": ".opencode/plugins/beacon.ts",
  "exports": {
    ".": "./.opencode/plugins/beacon.ts",
    "./config": "./config/beacon.default.json"
  }
}

{
  "none": {
    "description": "No embeddings — BM25-only keyword search (fastest, no AI model required)",
    "embedding": {
      "api_base": "",
      "model": "",
      "api_key_env": "",
      "dimensions": 384,
      "batch_size": 1,
      "query_prefix": "",
      "enabled": false
    }
  },
  "ollama": {
    "description": "Ollama (local) — all-minilm:22m, 384-dim, ~46MB, 4-6× faster than nomic-embed-text on CPU",
    "embedding": {
      "api_base": "http://localhost:11434/v1",
      "model": "all-minilm:22m",
      "api_key_env": "",
      "dimensions": 384,
      "batch_size": 50,
      "query_prefix": ""
    }
  },
  "ollama-nomic": {
    "description": "Ollama (local) — nomic-embed-text, 768-dim, higher quality for long documents",
    "embedding": {
      "api_base": "http://localhost:11434/v1",
      "model": "nomic-embed-text",
      "api_key_env": "",
      "dimensions": 768,
      "batch_size": 10,
      "query_prefix": "search_query: "
    }
  },
  "openai": {
    "description": "OpenAI",
    "embedding": {
      "api_base": "https://api.openai.com/v1",
      "model": "text-embedding-3-small",
      "api_key_env": "OPENAI_API_KEY",
      "dimensions": 1536,
      "batch_size": 100,
      "query_prefix": ""
    }
  },
  "voyage": {
    "description": "Voyage AI",
    "embedding": {
      "api_base": "https://api.voyageai.com/v1",
      "model": "voyage-code-3",
      "api_key_env": "VOYAGE_API_KEY",
      "dimensions": 1024,
      "batch_size": 50,
      "query_prefix": ""
    }
  },
  "litellm": {
    "description": "LiteLLM proxy (Vertex AI, Bedrock, etc.)",
    "embedding": {
      "api_base": "http://localhost:4000/v1",
      "model": "voyage-code-3",
      "api_key_env": "LITELLM_API_KEY",
      "dimensions": 1024,
      "batch_size": 50,
      "query_prefix": ""
    }
  }

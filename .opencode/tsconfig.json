{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020"],
    "moduleResolution": "bundler",
    "strict": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "outDir": "dist",
    "rootDir": "..",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "noEmitOnError": false,
    "allowImportingTsExtensions": true,
    "allowJs": true,
    "checkJs": false,
    "noImplicitAny": false
  },
  "include": [
    "tools/**/*.ts",
    "../src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".opencode/node_modules",
    "tests",
    "dist"
  ]
}

{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": false,
    "declarationMap": false,
    "sourceMap": true,
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "noEmit": false,
    "types": ["node"],
    "noImplicitAny": false,
    "strictNullChecks": false
  },
  "include": [
    "beacon.ts",
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "*.test.ts",
    "*.spec.ts"
  ]
}

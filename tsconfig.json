{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": false,
    "noEmit": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "types": ["bun-types"],
    "resolveJsonModule": true
  },
  "include": [
    "beacon.ts",
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "*.test.ts",
    "*.spec.ts",
    "test/**/*"
  ]
}
